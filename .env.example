# Your wallet address that receives USDC payments
SELLER_ADDRESS=0xYOUR_WALLET_ADDRESS

# Price per article in USD (e.g. 0.01 = $0.01 USDC)
ARTICLE_PRICE=0.01

# Chain for test scripts and withdrawals (default: arcTestnet)
# CHAIN=arcTestnet

# For testing: buyer private key (use a testnet key, never a mainnet key)
# BUYER_PRIVATE_KEY=0xYOUR_TEST_PRIVATE_KEY

# Seller private key — only needed for withdrawing earnings
# SELLER_PRIVATE_KEY=0xYOUR_SELLER_PRIVATE_KEY
